APP_NAME=CityPulse V2X Backend
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=false

FRONTEND_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

SUMO_HOME=/usr/share/sumo
SUMO_GENERATED_DIR=data/maps/sumo/generated
SUMO_SESSION_ROOT=outputs/sessions

DEFAULT_INTERSECTION_ID=demo_2
DEFAULT_MAP_RADIUS_METERS=600
DEFAULT_SNAPSHOT_INTERVAL_SECONDS=0.2

# ── 地图服务 Token（仅服务端保存，不下发天地图 Key）──
# Cesium Ion：通过 GET /api/v1/config/map 下发给前端
# 申请：https://ion.cesium.com/tokens
CESIUM_ION_TOKEN=

# 天地图：通过 GET /api/v1/tiles/tianditu/{layer}/wmts 代理，Key 不暴露给浏览器
# 申请：https://console.tianditu.gov.cn/
TIANDITU_TOKEN=

# SUMO worker 回调本进程内部算法协议的基址（需与实际监听端口一致）
# 实际路径形如：{ALGORITHM_BASE_URL}/api/v1/internal/algorithm/{control_mode}
ALGORITHM_BASE_URL=http://127.0.0.1:8000
ALGORITHM_TIMEOUT=2.0
DECISION_INTERVAL=5.0

# 可选：启用管控模式白名单（逗号分隔，必须是注册表子集）。留空=启用全部注册模式。
# ENABLED_CONTROL_MODES_CSV=fixed,max_pressure
