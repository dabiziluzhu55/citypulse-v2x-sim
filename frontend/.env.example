VITE_BACKEND_PROXY_TARGET=http://127.0.0.1:8000
VITE_API_BASE_URL=/api/v1
# 留空时自动使用当前页面 host，并通过 Vite /api WebSocket 代理连接后端。
VITE_TRAFFIC_WS_URL=
VITE_DEFAULT_RUN_ID=run_20260704_001
VITE_DEFAULT_EXPERIMENT_ID=
# Cesium ion access token — https://ion.cesium.com/tokens
VITE_CESIUM_ION_TOKEN=
# Tianditu browser-side application token
VITE_TIANDITU_TOKEN=
# Local Xiong'an 3D Tiles endpoint (served by backend)
VITE_XIONGAN_3DTILES_URL=/3dtiles/xiongan/tileset.json
