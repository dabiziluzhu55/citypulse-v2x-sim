# CityPulse V2X Frontend 境变量配置

# 复制为 .env 后填写。地图 Token 已移至 backend/.env



# 后端代理地址（仿真后端默认 8000 端口）

VITE_BACKEND_PROXY_TARGET=http://127.0.0.1:8000



# API 基础路径

VITE_API_BASE_URL=/api/v1



# WebSocket 地址（留空使用同源，通过 Vite 代理）

VITE_TRAFFIC_WS_URL=



# 开发服务器文件监视：若 npm run dev 报 ENOSPC，设为 1 使用轮询模式

# VITE_DEV_USE_POLLING=1



# 百度 JSAPI Three 浏览器端 AK

VITE_BAIDU_MAP_AK=

# 高德 JSAPI 浏览器端 Key，用于 /amap-3d-test 诊断页

VITE_AMAP_MAP_KEY=caffa74076c7fa91c91b133e0fa9fb20

# 可选：百度个性化地图样式 ID

VITE_BAIDU_MAP_STYLE=

# 仅用于坐标校准时显示百度道路，默认关闭以避免与自有道路重叠
VITE_BAIDU_ROADS=false



# 是否显示百度 3D 建筑。默认开启，当前主三维地图暂不加载本地 3D Tiles

VITE_BAIDU_BUILDINGS=true



# 是否加载本地雄安 3D Tiles。默认关闭，避免当前建筑数据长条/破面影响展示

VITE_ENABLE_XIONGAN_3DTILES=false



# 雄安彩色建筑 3D Tiles 由 frontend/public/3dtiles/xiongan/ 直接提供

# 一般仅在 VITE_ENABLE_XIONGAN_3DTILES=true 时使用

VITE_XIONGAN_3DTILES_URL=/3dtiles/xiongan-webmercator/tileset.json

# Static SUMO road mesh generated by npm run generate:road-tileset
VITE_ENABLE_STATIC_ROAD_3DTILES=true
VITE_STATIC_ROAD_3DTILES_URL=/3dtiles/roads/demo_2/tileset.json

# actual: keep SUMO WGS84 position; xiongan-demo: place roads and vehicles at the local building scene
VITE_3D_SCENE_PLACEMENT=actual
