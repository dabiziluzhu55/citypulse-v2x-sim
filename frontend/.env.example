# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# CityPulse V2X Frontend 环境变量配置
# 复制为 .env 后按需填写。仓库不包含任何真实 Token。
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# 后端代理地址（仿真后端默认 8000 端口）
VITE_BACKEND_PROXY_TARGET=http://127.0.0.1:8000

# API 基础路径
VITE_API_BASE_URL=/api/v1

# WebSocket 地址（留空使用同源，通过 Vite 代理）
VITE_TRAFFIC_WS_URL=

# ── Cesium Ion Token ──
# 用途：加载 Cesium World Terrain（地形起伏）和 OSM Buildings 回退建筑
# 获取：https://ion.cesium.com/tokens — 免费注册后创建 Token
# 留空时不加载对应的在线服务
VITE_CESIUM_ION_TOKEN=

# ── 天地图 Token ──
# 用途：3D 模式下的卫星影像底图和中文注记
# 获取：https://console.tianditu.gov.cn/ — 注册开发者账号，创建浏览器端应用获取 Key
# 留空时不加载对应的在线服务
VITE_TIANDITU_TOKEN=

# ── 3D Tiles 路径 ──
# 雄安彩色建筑 3D Tiles 由 frontend/public/3dtiles/xiongan/ 直接提供
# 无需启动后端即可加载，一般无需修改
VITE_XIONGAN_3DTILES_URL=/3dtiles/xiongan/tileset.json
